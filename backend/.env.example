# =============================================================================
# GCC Bond Trading Platform — Environment Variables
# Copy to .env and fill in values. Never commit .env to git.
# =============================================================================

# ── PostgreSQL ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://gccbond:CHANGE_ME@postgresql:5432/gccbond
POSTGRES_DB=gccbond
POSTGRES_USER=gccbond
POSTGRES_PASSWORD=CHANGE_ME

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://:CHANGE_ME@redis:6379
REDIS_PASSWORD=CHANGE_ME

# ── MongoDB ───────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://gccbond:CHANGE_ME@mongodb:27017/gccbond?authSource=admin
MONGO_USER=gccbond
MONGO_PASSWORD=CHANGE_ME

# ── RabbitMQ ──────────────────────────────────────────────────────────────────
RABBITMQ_URL=amqp://gccbond:CHANGE_ME@rabbitmq:5672/gcc-bond
RABBITMQ_USER=gccbond
RABBITMQ_PASSWORD=CHANGE_ME

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=GENERATE_32_CHAR_RANDOM_STRING
JWT_REFRESH_SECRET=GENERATE_DIFFERENT_32_CHAR_STRING
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── Encryption ────────────────────────────────────────────────────────────────
ENCRYPTION_KEY=GENERATE_32_BYTE_HEX_STRING

# ── Service-to-Service ────────────────────────────────────────────────────────
SERVICE_SECRET=GENERATE_32_CHAR_SECRET

# ── CORS ──────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:4200,https://app.gccbond.com

# ── .NET Service URLs (dev only) ──────────────────────────────────────────────
DOTNET_TRADING_URL=http://dotnet-trading:5001
DOTNET_AML_URL=http://dotnet-aml:5005

# ── Onfido (KYC) ──────────────────────────────────────────────────────────────
ONFIDO_API_KEY=
ONFIDO_WEBHOOK_SECRET=

# ── HyperPay (Payments) ───────────────────────────────────────────────────────
HYPERPAY_API_KEY=
HYPERPAY_ENTITY_ID=
HYPERPAY_WEBHOOK_SECRET=

# ── SendGrid (Email) ──────────────────────────────────────────────────────────
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@gccbond.com

# ── Unifonic (SMS) ────────────────────────────────────────────────────────────
UNIFONIC_API_KEY=
UNIFONIC_SENDER_ID=GCCBond

# ── Firebase (Push) ───────────────────────────────────────────────────────────
FCM_SERVER_KEY=

# ── App ───────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000
API_VERSION=v1
