# ── Server ──────────────────────────────────────────────
NODE_ENV=development
PORT=3000
API_VERSION=v1

# ── PostgreSQL ───────────────────────────────────────────
DATABASE_URL=postgresql://gcc_user:gcc_pass@localhost:5432/gcc_bond_db
DB_POOL_MIN=2
DB_POOL_MAX=20

# ── Redis ────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_TTL_SESSION=604800         # 7 days in seconds
REDIS_TTL_OTP=300                # 5 minutes

# ── MongoDB ──────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/gcc_bond_audit

# ── RabbitMQ ─────────────────────────────────────────────
RABBITMQ_URL=amqp://guest:guest@localhost:5672
RABBITMQ_EXCHANGE=gcc.bond.events
RABBITMQ_DLX=gcc.bond.dlx

# ── JWT ──────────────────────────────────────────────────
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d
JWT_ALGORITHM=RS256

# ── Keycloak ─────────────────────────────────────────────
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=gcc-bond
KEYCLOAK_CLIENT_ID=gcc-bond-api
KEYCLOAK_CLIENT_SECRET=your-keycloak-client-secret

# ── Onfido (KYC) ─────────────────────────────────────────
ONFIDO_API_KEY=your-onfido-api-key
ONFIDO_WEBHOOK_SECRET=your-onfido-webhook-secret
ONFIDO_LIVENESS_THRESHOLD=0.8

# ── HyperPay (Payments) ──────────────────────────────────
HYPERPAY_URL=https://eu-test.oppwa.com
HYPERPAY_ENTITY_ID=your-entity-id
HYPERPAY_ACCESS_TOKEN=your-access-token
HYPERPAY_WEBHOOK_SECRET=your-webhook-secret

# ── SendGrid (Email) ─────────────────────────────────────
SENDGRID_API_KEY=your-sendgrid-api-key
SENDGRID_FROM_EMAIL=noreply@gccbond.com
SENDGRID_FROM_NAME=GCC Bond Trading

# ── Unifonic (SMS) ───────────────────────────────────────
UNIFONIC_APP_SID=your-unifonic-app-sid
UNIFONIC_BASE_URL=https://el.cloud.unifonic.com

# ── FCM (Push Notifications) ─────────────────────────────
FCM_PROJECT_ID=your-firebase-project-id
FCM_PRIVATE_KEY=your-firebase-private-key
FCM_CLIENT_EMAIL=your-firebase-client-email

# ── Azure Key Vault ───────────────────────────────────────
AZURE_KEYVAULT_URL=https://your-vault.vault.azure.net
AZURE_CLIENT_ID=your-azure-client-id
AZURE_CLIENT_SECRET=your-azure-client-secret
AZURE_TENANT_ID=your-azure-tenant-id

# ── Encryption ───────────────────────────────────────────
ENCRYPTION_KEY=your-32-byte-aes-256-encryption-key-here
ENCRYPTION_IV=your-16-byte-iv-here

# ── Rate Limiting ─────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# ── Trading ──────────────────────────────────────────────
DOTNET_TRADING_URL=http://localhost:5000
TRADING_HOURS_START=09:00
TRADING_HOURS_END=17:00
TRADING_TIMEZONE=Asia/Riyadh

# ── AML ──────────────────────────────────────────────────
AML_LARGE_TRANSACTION_THRESHOLD=10000
AML_SANCTIONS_API_KEY=your-dow-jones-api-key
