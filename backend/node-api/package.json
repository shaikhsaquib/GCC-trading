{
  "name": "gcc-bond-node-api",
  "version": "1.0.0",
  "description": "GCC Bond Trading Platform — Node.js API Gateway",
  "main": "dist/server.js",
  "scripts": {
    "dev":        "ts-node-dev --respawn --transpile-only src/server.ts",
    "build":      "tsc --project tsconfig.json",
    "start":      "node dist/server.js",
    "start:prod": "NODE_ENV=production node dist/server.js",
    "test":       "jest --coverage --forceExit",
    "test:watch": "jest --watch",
    "lint":        "eslint 'src/**/*.ts' --max-warnings 0",
    "typecheck":   "tsc --noEmit",
    "create-admin": "ts-node --transpile-only scripts/create-admin.ts"
  },
  "dependencies": {
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "compression": "^1.7.4",
    "morgan": "^1.10.0",
    "dotenv": "^16.3.1",
    "pg": "^8.11.3",
    "ioredis": "^5.3.2",
    "mongoose": "^8.0.3",
    "amqplib": "^0.10.3",
    "jsonwebtoken": "^9.0.2",
    "bcryptjs": "^2.4.3",
    "speakeasy": "^2.0.0",
    "qrcode": "^1.5.3",
    "multer": "^1.4.5-lts.1",
    "axios": "^1.6.2",
    "uuid": "^9.0.0",
    "winston": "^3.11.0",
    "winston-elasticsearch": "^0.17.4",
    "@sendgrid/mail": "^8.1.0",
    "node-cron": "^3.0.3",
    "ws": "^8.16.0",
    "zod": "^3.22.4",
    "crypto": "^1.0.1",
    "http-proxy-middleware": "^3.0.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.17",
    "@types/compression": "^1.7.5",
    "@types/morgan": "^1.9.9",
    "@types/pg": "^8.10.9",
    "@types/amqplib": "^0.10.4",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/bcryptjs": "^2.4.6",
    "@types/speakeasy": "^2.0.10",
    "@types/qrcode": "^1.5.5",
    "@types/multer": "^1.4.11",
    "@types/uuid": "^9.0.7",
    "@types/node-cron": "^3.0.11",
    "@types/ws": "^8.5.10",
    "@types/node": "^20.10.0",
    "typescript": "^5.3.2",
    "ts-node-dev": "^2.0.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "@types/jest": "^29.5.10"
  }
}
