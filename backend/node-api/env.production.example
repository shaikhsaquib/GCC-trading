# ── .env.production.example ───────────────────────────────────────────────────
# Copy this to .env on your server, or paste each value into Render dashboard.
# All services below are FREE tier.

# ── Server ────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000
API_VERSION=v1

# ── PostgreSQL — Neon.tech (free 512 MB) ──────────────────────────────────────
# Sign up: https://neon.tech  → New Project → copy "Connection string"
# Enable pooler mode (PgBouncer) for serverless cold-start compatibility.
DATABASE_URL=postgresql://user:pass@ep-cool-name-123456.us-east-2.aws.neon.tech/neondb?sslmode=require&pgbouncer=true&connect_timeout=15
DB_POOL_MIN=1
DB_POOL_MAX=5

# ── Redis — Upstash (free 10 K cmds/day, 256 MB) ─────────────────────────────
# Sign up: https://upstash.com → New Database → copy "Redis URL (TLS)"
REDIS_URL=rediss://default:XXXXXXXXXXXXX@xxx-xxx.upstash.io:6379
REDIS_TTL_SESSION=604800
REDIS_TTL_OTP=300

# ── MongoDB — MongoDB Atlas M0 (free 512 MB) ──────────────────────────────────
# Sign up: https://cloud.mongodb.com → Free cluster → Connect → Drivers
# Allow access from 0.0.0.0/0 in Network Access for Render's dynamic IPs.
MONGODB_URI=mongodb+srv://gcc_user:XXXXXXXXXXXXX@cluster0.abcde.mongodb.net/gcc_bond_audit?retryWrites=true&w=majority

# ── RabbitMQ — CloudAMQP Little Lemur (free 1 M msgs/month) ──────────────────
# Sign up: https://www.cloudamqp.com → Little Lemur plan → copy AMQP URL
RABBITMQ_URL=amqps://gcc_user:XXXXXXXXXXXXX@rattlesnake.rmq.cloudamqp.com/gcc_user
RABBITMQ_EXCHANGE=gcc.bond.events
RABBITMQ_DLX=gcc.bond.dlx

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=REPLACE_WITH_64_BYTE_HEX_SECRET
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d
JWT_ALGORITHM=HS256

# ── Encryption (AES-256-CBC) ──────────────────────────────────────────────────
# KEY: exactly 32 ASCII chars  → node -e "console.log(require('crypto').randomBytes(16).toString('hex'))"
# IV:  exactly 16 ASCII chars  → node -e "console.log(require('crypto').randomBytes(8).toString('hex'))"
ENCRYPTION_KEY=REPLACE_WITH_32_ASCII_CHARS_EXACTLY
ENCRYPTION_IV=REPLACE_WITH_16_ASCII_CHARS_EXACTLY

# ── .NET microservices — Railway (free $5 credit/month) ───────────────────────
# After deploying via railway/ configs, paste the generated public URLs here.
DOTNET_TRADING_URL=https://gcc-dotnet-trading.up.railway.app

# ── SendGrid (optional — free 100 emails/day) ─────────────────────────────────
# Sign up: https://sendgrid.com → Settings → API Keys
SENDGRID_API_KEY=SG.XXXXXXXXXXXXX
SENDGRID_FROM_EMAIL=noreply@yourdomain.com
SENDGRID_FROM_NAME=GCC Bond Trading

# ── Unifonic SMS (optional) ───────────────────────────────────────────────────
UNIFONIC_APP_SID=XXXXXXXXXXXXX
UNIFONIC_BASE_URL=https://el.cloud.unifonic.com

# ── Firebase FCM (optional — free tier) ──────────────────────────────────────
# Firebase Console → Project Settings → Service Accounts → Generate new private key
FCM_PROJECT_ID=your-firebase-project-id
FCM_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nXXX\n-----END PRIVATE KEY-----\n"
FCM_CLIENT_EMAIL=firebase-adminsdk-xxx@your-project.iam.gserviceaccount.com

# ── Onfido KYC (optional) ─────────────────────────────────────────────────────
ONFIDO_API_KEY=XXXXXXXXXXXXX
ONFIDO_WEBHOOK_SECRET=XXXXXXXXXXXXX
ONFIDO_LIVENESS_THRESHOLD=0.8

# ── HyperPay (optional) ───────────────────────────────────────────────────────
HYPERPAY_URL=https://eu-test.oppwa.com
HYPERPAY_ENTITY_ID=XXXXXXXXXXXXX
HYPERPAY_ACCESS_TOKEN=XXXXXXXXXXXXX
HYPERPAY_WEBHOOK_SECRET=XXXXXXXXXXXXX

# ── OAuth social login (optional) ─────────────────────────────────────────────
# Google: console.cloud.google.com → Credentials → OAuth 2.0 Client IDs
# Authorized redirect URI: https://YOUR-VERCEL-APP.vercel.app/auth/oauth/callback
GOOGLE_CLIENT_ID=XXXXXXXXXXXXX.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-XXXXXXXXXXXXX
# Microsoft: portal.azure.com → App Registrations
# Authorized redirect URI: https://YOUR-VERCEL-APP.vercel.app/auth/oauth/callback
MICROSOFT_CLIENT_ID=XXXXXXXXXXXXX
MICROSOFT_CLIENT_SECRET=XXXXXXXXXXXXX
MICROSOFT_TENANT_ID=common

# ── AML ───────────────────────────────────────────────────────────────────────
AML_LARGE_TRANSACTION_THRESHOLD=10000

# ── Trading hours (Gulf Standard Time) ───────────────────────────────────────
TRADING_HOURS_START=09:00
TRADING_HOURS_END=17:00
TRADING_TIMEZONE=Asia/Riyadh

# ── Rate limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
